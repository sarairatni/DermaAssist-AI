{
  "name": "dermassist-patient-mobile",
  "version": "1.0.0",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build": "eas build",
    "build:android": "eas build --platform android",
    "build:ios": "eas build --platform ios",
    "submit": "eas submit"
  },
  "dependencies": {
    "expo": "^49.0.0",
    "react": "^18.2.0",
    "react-native": "^0.72.3",
    "expo-image-picker": "^14.3.0",
    "axios": "^1.6.0",
    "zustand": "^4.4.0",
    "@react-navigation/native": "^6.1.0",
    "@react-navigation/bottom-tabs": "^6.5.0",
    "@react-navigation/stack": "^6.3.0",
    "react-native-screens": "^3.27.0",
    "react-native-safe-area-context": "^4.8.0",
    "react-native-uuid": "^2.0.0",
    "date-fns": "^2.30.0",
    "expo-notifications": "^0.20.0"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "babel-preset-expo": "^9.2.0"
  },
  "expo": {
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "The app accesses your photos to send them for skin analysis",
          "cameraPermission": "The app accesses your camera to take photos for skin analysis"
        }
      ]
    ]
  }
}
